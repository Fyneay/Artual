{
  "name": "@skeletonlabs/skeleton-svelte",
  "version": "4.0.2",
  "description": "The Svelte package for Skeleton.",
  "author": "endigo9740 <chris@skeletonlabs.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skeletonlabs/skeleton.git",
    "directory": "packages/skeleton-svelte"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "style": "./dist/index.css",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "sideEffects": false,
  "dependencies": {
    "@zag-js/accordion": "1.26.1",
    "@zag-js/avatar": "1.26.1",
    "@zag-js/collapsible": "1.26.1",
    "@zag-js/collection": "1.26.1",
    "@zag-js/combobox": "1.26.1",
    "@zag-js/date-picker": "1.26.1",
    "@zag-js/dialog": "1.26.1",
    "@zag-js/file-upload": "1.26.1",
    "@zag-js/listbox": "1.26.1",
    "@zag-js/pagination": "1.26.1",
    "@zag-js/popover": "1.26.1",
    "@zag-js/progress": "1.26.1",
    "@zag-js/radio-group": "1.26.1",
    "@zag-js/rating-group": "1.26.1",
    "@zag-js/slider": "1.26.1",
    "@zag-js/svelte": "1.26.1",
    "@zag-js/switch": "1.26.1",
    "@zag-js/tabs": "1.26.1",
    "@zag-js/tags-input": "1.26.1",
    "@zag-js/toast": "1.26.1",
    "@zag-js/tooltip": "1.26.1",
    "@zag-js/tree-view": "1.26.1",
    "@skeletonlabs/skeleton-common": "4.0.2"
  },
  "peerDependencies": {
    "svelte": "^5.29.0"
  },
  "devDependencies": {
    "@sveltejs/kit": "2.46.5",
    "@sveltejs/package": "2.5.4",
    "@sveltejs/vite-plugin-svelte": "6.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.2.8",
    "jsdom": "27.0.0",
    "svelte": "5.39.12",
    "svelte-check": "4.3.3",
    "typescript": "5.9.3",
    "vite": "7.1.9",
    "vitest": "3.2.4",
    "@skeletonlabs/skeleton": "4.0.2"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "svelte-package --input src --output dist --watch",
    "build": "svelte-package --input src --output dist",
    "test": "vitest run",
    "check": "svelte-check",
    "sync": "svelte-kit sync && pnpm build"
  }
}